{
  "name": "@profullstack/autoblog",
  "version": "0.3.0",
  "description": "CloudEvents + Standard Webhooks SDK for autoblog publishing. Build and send normalized post-published events from a CMS or AI writer; verify, parse, and quality-gate them in your blog receiver.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./quality": {
      "import": {
        "types": "./dist/quality.d.ts",
        "default": "./dist/quality.js"
      },
      "require": {
        "types": "./dist/quality.d.cts",
        "default": "./dist/quality.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "webhook",
    "cloudevents",
    "standard-webhooks",
    "blog",
    "autoblog",
    "crawlproof"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/profullstack/autoblog.git"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  }
}
